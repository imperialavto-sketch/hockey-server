# Required
NODE_ENV=production
PORT=3000
DATABASE_URL="postgresql://user:password@host:5432/hockey_id?schema=public"

# CORS (production). Comma-separated origins, e.g. https://app.example.com,exp://...
ALLOWED_ORIGINS=

# AI (Coach Mark). Required for live responses. https://platform.openai.com/api-keys
OPENAI_API_KEY=

# SMS (production mobile auth). Optional for deploy; required for SMS delivery.
# SMS_PROVIDER=smsru
# SMS_API_KEY=
# SMS_SENDER=

# Optional. Default 0.0.0.0 for external access.
# HOST=0.0.0.0
